<script>
renderSidebar('financeiro');

function rFin(){
const db=getDB();
const rec=db.nfs.filter(n=>n.tipo===‘saida’).reduce((s,n)=>s+parseFloat(n.val||0),0);
const cProd=db.custos_prod.reduce((s,c)=>s+parseFloat(c.qtd||0)*parseFloat(c.val||0),0);
const cOp=db.custos_op.reduce((s,c)=>s+parseFloat(c.val||0),0);
const cProm=db.custos_prom.reduce((s,c)=>s+parseFloat(c.val||0),0);
const cTot=cProd+cOp+cProm;
const res=rec-cTot;

// KPIs
document.getElementById(‘kpi-fin’).innerHTML=[
{lbl:‘Receita Total’,val:brl(rec),color:‘var(–success)’},
{lbl:‘Custo Total’,val:brl(cTot),color:‘var(–danger)’},
{lbl:‘Resultado’,val:brl(res),color:res>=0?‘var(–success)’:‘var(–danger)’},
{lbl:‘NFs Emitidas’,val:db.nfs.length,color:‘var(–p)’},
].map(k=>`<div class="fin-card"><div class="fin-lbl">${k.lbl}</div><div class="fin-val" style="color:${k.color}">${typeof k.val==='number'?k.val:k.val}</div></div>`).join(’’);

// DRE
const mg=rec>0?((rec-cProd)/rec*100).toFixed(1):0;
document.getElementById(‘dre-view’).innerHTML=` <div class="tf"><div class="tf-l">Receita Bruta (NF saída)</div><div class="tf-v" style="color:var(--success);font-weight:600">${brl(rec)}</div></div> <div class="tf"><div class="tf-l">(-) Custo dos Produtos</div><div class="tf-v" style="color:var(--danger)">${brl(cProd)}</div></div> <div class="tf"><div class="tf-l">= Lucro Bruto</div><div class="tf-v" style="font-weight:600">${brl(rec-cProd)} <small style="color:var(--muted)">(${mg}%)</small></div></div> <div class="tf"><div class="tf-l">(-) Despesas Operacionais</div><div class="tf-v" style="color:var(--danger)">${brl(cOp)}</div></div> <div class="tf"><div class="tf-l">(-) Despesas Promoção</div><div class="tf-v" style="color:var(--danger)">${brl(cProm)}</div></div> <div class="tf"><div class="tf-l"><strong>= Resultado Líquido</strong></div><div class="tf-v" style="font-weight:700;font-size:15px;color:${res>=0?'var(--success)':'var(--danger)'}">${brl(res)}</div></div>`;

// Margem por produto
const prods=db.produtos.filter(p=>p.custo&&p.varejo);
document.getElementById(‘margem-view’).innerHTML=prods.length?prods.map(p=>{const m=((1-parseFloat(p.custo)/parseFloat(p.varejo))*100).toFixed(1);const mc=parseFloat(m)>=70?‘var(–success)’:parseFloat(m)>=60?‘var(–warning)’:‘var(–danger)’;return`<div class="tf"><div class="tf-l" style="font-size:12px">${p.nome}</div><div class="tf-v"><div style="display:flex;justify-content:space-between"><span style="font-size:11px">${brl(p.custo)} → ${brl(p.varejo)}</span><span style="font-weight:600;color:${mc}">${m}%</span></div><div class="progress-bar"><div class="progress-fill" style="width:${m}%;background:${mc}"></div></div></div></div>`;}).join(’’):’<div class="ib tip">Preencha custo e preço de varejo nos produtos.</div>’;

// BOM
const byProd={};
db.custos_prod.forEach(c=>{if(c.prod_nome){byProd[c.prod_nome]=(byProd[c.prod_nome]||0)+parseFloat(c.qtd||0)*parseFloat(c.val||0);}});
document.getElementById(‘bom-view’).innerHTML=Object.keys(byProd).length?Object.entries(byProd).map(([pn,tot])=>`<div class="tf"><div class="tf-l" style="font-size:12px">${pn}</div><div class="tf-v" style="font-weight:500">${brl(tot)}</div></div>`).join(’’):’<div class="ib tip">Registre custos por produto para calcular o BOM.</div>’;

// Distribuição
const dist=[{l:‘Custo Produto’,v:cProd,c:‘var(–p)’},{l:‘Operacional’,v:cOp,c:‘var(–accent)’},{l:‘Promoção’,v:cProm,c:‘var(–sage)’}];
document.getElementById(‘dist-view’).innerHTML=cTot>0?dist.map(d=>`<div style="margin-bottom:12px"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px"><span>${d.l}</span><span style="font-weight:500">${brl(d.v)} (${(d.v/cTot*100).toFixed(1)}%)</span></div><div class="progress-bar"><div class="progress-fill" style="width:${d.v/cTot*100}%;background:${d.c}"></div></div></div>`).join(’’):’<div class="ib tip">Nenhum custo registrado ainda.</div>’;

// Tabelas
rCpTabela(db);rOpTabela(db);rPromTabela(db);rNfTabela(db);
}

function rCpTabela(db){
const tb=document.getElementById(‘tb-cp’),emp=document.getElementById(‘emp-cp’);
if(!db.custos_prod.length){tb.innerHTML=’’;emp.style.display=‘block’;return;}emp.style.display=‘none’;
tb.innerHTML=db.custos_prod.map(c=>{const tot=parseFloat(c.qtd||0)*parseFloat(c.val||0);return`<tr><td>${c.prod_nome||'—'}</td><td>${c.item||'—'}</td><td style="font-size:11px">${c.forn_nome||'—'}</td><td>${c.qtd||0}</td><td>${c.unid||''}</td><td>${brl(c.val)}</td><td>${brl(tot)}</td><td>${c.perc?c.perc+'%':'—'}</td><td style="font-size:11px">${c.data||'—'}</td><td><button class="btn-ic" onclick="delRec('prod','${c.id}')" style="border-color:var(--danger);color:var(--danger)">🗑</button></td></tr>`;}).join(’’);
}
function rOpTabela(db){
const tb=document.getElementById(‘tb-op’),emp=document.getElementById(‘emp-op’);
const tot=db.custos_op.reduce((s,c)=>s+parseFloat(c.val||0),0);
document.getElementById(‘tot-op’).textContent=brl(tot);
if(!db.custos_op.length){tb.innerHTML=’’;emp.style.display=‘block’;return;}emp.style.display=‘none’;
tb.innerHTML=db.custos_op.map(c=>`<tr><td>${c.desc}</td><td><span class="badge bg-blue">${c.cat}</span></td><td>${brl(c.val)}</td><td>${c.rec}</td><td style="font-size:11px">${c.data||'—'}</td><td><button class="btn-ic" onclick="delRec('op','${c.id}')" style="border-color:var(--danger);color:var(--danger)">🗑</button></td></tr>`).join(’’);
}
function rPromTabela(db){
const tb=document.getElementById(‘tb-prom’),emp=document.getElementById(‘emp-prom’);
const tot=db.custos_prom.reduce((s,c)=>s+parseFloat(c.val||0),0);
document.getElementById(‘tot-prom’).textContent=brl(tot);
if(!db.custos_prom.length){tb.innerHTML=’’;emp.style.display=‘block’;return;}emp.style.display=‘none’;
tb.innerHTML=db.custos_prom.map(c=>`<tr><td>${c.desc}</td><td><span class="badge bg-sage">${c.canal}</span></td><td>${brl(c.val)}</td><td style="font-size:11px">${c.roi||'—'}</td><td style="font-size:11px">${c.data||'—'}</td><td><button class="btn-ic" onclick="delRec('prom','${c.id}')" style="border-color:var(--danger);color:var(--danger)">🗑</button></td></tr>`).join(’’);
}
function rNfTabela(db){
const tb=document.getElementById(‘tb-nf’),emp=document.getElementById(‘emp-nf’);
const sai=db.nfs.filter(n=>n.tipo===‘saida’).reduce((s,n)=>s+parseFloat(n.val||0),0);
const ent=db.nfs.filter(n=>n.tipo!==‘saida’).reduce((s,n)=>s+parseFloat(n.val||0),0);
document.getElementById(‘tot-nf-sai’).textContent=brl(sai);
document.getElementById(‘tot-nf-ent’).textContent=brl(ent);
if(!db.nfs.length){tb.innerHTML=’’;emp.style.display=‘block’;return;}emp.style.display=‘none’;
tb.innerHTML=db.nfs.map(n=>`<tr><td><strong>${n.num}</strong></td><td><span class="badge ${n.tipo==='saida'?'bg-green':n.tipo==='entrada'?'bg-amber':'bg-blue'}">${n.tipo}</span></td><td>${n.ent||'—'}</td><td>${brl(n.val)}</td><td style="font-size:11px">${n.data||'—'}</td><td>${badge(n.status)}</td><td style="font-size:11px;max-width:180px;overflow:hidden;text-overflow:ellipsis">${n.desc||'—'}</td><td><button class="btn-ic" onclick="delRec('nf','${n.id}')" style="border-color:var(--danger);color:var(--danger)">🗑</button></td></tr>`).join(’’);
}

function popCpSelects(){
const db=getDB();
document.getElementById(‘cp-prod’).innerHTML=’<option value="">— Produto —</option>’+db.produtos.map(p=>`<option value="${p.id}" data-nome="${p.nome}">${p.nome}</option>`).join(’’);
document.getElementById(‘cp-forn’).innerHTML=’<option value="">— Fornecedor —</option>’+db.fornecedores.map(f=>`<option value="${f.id}" data-nome="${f.nome}">${f.nome}</option>`).join(’’);
}

function saveCp(){
const db=getDB();
const pSel=document.getElementById(‘cp-prod’);const fSel=document.getElementById(‘cp-forn’);
const pNome=pSel.options[pSel.selectedIndex]?.dataset?.nome||’’;
const fNome=fSel.options[fSel.selectedIndex]?.dataset?.nome||’’;
db.custos_prod.push({id:genID(),prod_id:pSel.value,prod_nome:pNome,forn_id:fSel.value,forn_nome:fNome,item:document.getElementById(‘cp-item’).value.trim(),qtd:document.getElementById(‘cp-qtd’).value,unid:document.getElementById(‘cp-unid’).value,val:document.getElementById(‘cp-val’).value,perc:document.getElementById(‘cp-perc’).value,data:document.getElementById(‘cp-data’).value});
saveDB(db);closeM(‘m-cp’);rFin();toast(‘Custo registrado!’,‘s’);
}
function saveOp(){
const db=getDB();
db.custos_op.push({id:genID(),desc:document.getElementById(‘op-desc’).value.trim(),cat:document.getElementById(‘op-cat’).value,rec:document.getElementById(‘op-rec’).value,val:document.getElementById(‘op-val’).value,data:document.getElementById(‘op-data’).value});
saveDB(db);closeM(‘m-op’);rFin();toast(‘Custo operacional salvo!’,‘s’);
}
function saveProm(){
const db=getDB();
db.custos_prom.push({id:genID(),desc:document.getElementById(‘pm-desc’).value.trim(),canal:document.getElementById(‘pm-canal’).value,val:document.getElementById(‘pm-val’).value,data:document.getElementById(‘pm-data’).value,roi:document.getElementById(‘pm-roi’).value.trim()});
saveDB(db);closeM(‘m-prom’);rFin();toast(‘Custo promocional salvo!’,‘s’);
}
function saveNf(){
const db=getDB();
db.nfs.push({id:genID(),num:document.getElementById(‘nf-num’).value.trim(),tipo:document.getElementById(‘nf-tipo’).value,ent:document.getElementById(‘nf-ent’).value.trim(),val:document.getElementById(‘nf-val’).value,data:document.getElementById(‘nf-data’).value,status:document.getElementById(‘nf-status’).value,desc:document.getElementById(‘nf-desc’).value.trim()});
saveDB(db);closeM(‘m-nf’);rFin();toast(‘NF registrada!’,‘s’);
}
function delRec(tipo,id){
if(!confirm(‘Excluir registro?’))return;const db=getDB();
if(tipo===‘prod’)db.custos_prod=db.custos_prod.filter(x=>x.id!==id);
if(tipo===‘op’)db.custos_op=db.custos_op.filter(x=>x.id!==id);
if(tipo===‘prom’)db.custos_prom=db.custos_prom.filter(x=>x.id!==id);
if(tipo===‘nf’)db.nfs=db.nfs.filter(x=>x.id!==id);
saveDB(db);rFin();toast(‘Removido’,‘s’);
}

// FIX: Usar MODAL_OPEN_HOOKS em vez de window.openM override
MODAL_OPEN_HOOKS[‘m-cp’] = popCpSelects;

rFin();
</script>


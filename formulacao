<script>
renderSidebar('formulacao');
function rPr(){
  const db=getDB();const q=(document.getElementById('q-pr')?.value||"").toLowerCase();
  const fc=document.getElementById('fil-cat').value;const fp=document.getElementById('fil-pst').value;
  let list=db.produtos.filter(p=>(p.nome?.toLowerCase().includes(q)||p.categoria?.toLowerCase().includes(q))&&(!fc||p.categoria===fc)&&(!fp||p.pstatus===fp));
  const grid=document.getElementById('grid-pr'),emp=document.getElementById('emp-pr');
  if(!list.length){grid.style.display='none';emp.style.display='block';return;}
  emp.style.display='none';grid.style.display='grid';
  grid.innerHTML=list.map(p=>`<div class="prod-card" onclick="viewPr('${p.id}')">
    <div class="pc-hdr"><div class="pc-name">${p.nome}</div><div class="pc-cat">${p.linha?p.linha+" · ":""}${p.categoria||"—"}</div></div>
    <div class="pc-body">
      <div style="display:flex;gap:5px;margin-bottom:8px;flex-wrap:wrap">${badge(p.pstatus)}${badge(p.sanv)}</div>
      ${p.ativo?`<div style="font-size:11px;color:var(--muted)">🧪 ${p.ativo} ${p.conc||""}</div>`:""}
      ${p.custo&&p.varejo?`<div style="font-size:11px;margin-top:4px;color:var(--success);font-weight:500">Margem: ${((1-parseFloat(p.custo)/parseFloat(p.varejo))*100).toFixed(1)}%</div>`:""}
      <div style="display:flex;gap:5px;margin-top:10px" onclick="event.stopPropagation()">
        <button class="btn btn-o btn-sm" onclick="editPr('${p.id}')">✏️</button>
        <button class="btn btn-d btn-sm" onclick="delPr('${p.id}')">🗑</button>
      </div>
    </div></div>`).join("");
  buildPipeline();buildBOM();
}
function buildPipeline(){
  const db=getDB();
  const stages=[{key:'desenvolvimento',label:'Em Desenvolvimento'},{key:'aprovacao',label:'Ag. Aprovação'},{key:'ativo',label:'Ativo'},{key:'descontinuado',label:'Descontinuado'}];
  document.getElementById('pipeline-view').innerHTML=`<div style="display:flex;gap:10px;overflow-x:auto;padding-bottom:4px">${stages.map(s=>{const ps=db.produtos.filter(p=>p.pstatus===s.key);return`<div style="flex:1;min-width:140px;background:var(--s2);border-radius:8px;padding:10px"><div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:8px">${s.label} (${ps.length})</div>${ps.map(p=>`<div style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px;margin-bottom:6px;font-size:11.5px"><strong>${p.nome}</strong><br><span style="color:var(--muted)">${p.categoria||"—"}</span></div>`).join("")}</div>`;}).join("")}</div>`;
  document.getElementById('marcos-view').innerHTML=db.produtos.filter(p=>p.sanv==='em_processo').map(p=>`<div class="alert-item warn"><span>⏳</span><span><strong>${p.nome}</strong> — Regularização Anvisa em andamento</span></div>`).join("")||'<div class="ib ok">Nenhum marco pendente crítico.</div>';
}
function buildBOM(){
  const db=getDB();
  const prods=db.produtos.filter(p=>p.custo&&p.varejo);
  document.getElementById('bom-view').innerHTML=prods.length?prods.map(p=>{const m=((1-parseFloat(p.custo)/parseFloat(p.varejo))*100).toFixed(1);const mc=parseFloat(m)>=75?'var(--success)':parseFloat(m)>=60?'var(--warning)':'var(--danger)';return`<div class="tf"><div class="tf-l" style="font-size:11.5px">${p.nome}</div><div class="tf-v"><div style="display:flex;justify-content:space-between"><span>Custo: ${brl(p.custo)} | Varejo: ${brl(p.varejo)}</span><span style="font-weight:600;color:${mc}">${m}%</span></div><div class="progress-bar" style="margin-top:4px"><div class="progress-fill" style="width:${m}%;background:${mc}"></div></div></div></div>`;}).join(""):"<div class='ib tip'>Preencha custo e preço de varejo nos produtos para ver o BOM.</div>";
}
function savePr(){
  const id=document.getElementById('p-id').value,db=getDB();
  const fields=['nome','linha','pub','ph','desc','uso','val','pao','inci','ativo','conc','origem','obs_f','num_anv','venc_anv','claims','rest','laudos','vol','custo','varejo','atacado','canais'];
  const o={id:id||genID()};fields.forEach(k=>{const el=document.getElementById('p-'+k);if(el)o[k]=el.value?.trim?.()||el.value;});
  o.categoria=document.getElementById('p-cat').value;o.forma=document.getElementById('p-forma').value;o.grau=document.getElementById('p-grau').value;o.sanv=document.getElementById('p-sanv').value;o.pstatus=document.getElementById('p-pstatus').value;
  if(!o.nome){toast('Nome obrigatório','e');return;}
  if(id){const i=db.produtos.findIndex(x=>x.id===id);if(i>=0)db.produtos[i]={...db.produtos[i],...o};}else db.produtos.push(o);
  saveDB(db);closeM('m-prod');rPr();toast(id?'Produto atualizado!':'Formulação salva!','s');document.getElementById('p-id').value='';
}
function editPr(id){
  const db=getDB(),p=db.produtos.find(x=>x.id===id);if(!p)return;
  document.getElementById('p-id').value=p.id;
  ['nome','linha','pub','ph','desc','uso','val','pao','inci','ativo','conc','origem','obs_f','num_anv','venc_anv','claims','rest','laudos','vol','custo','varejo','atacado','canais'].forEach(k=>{const el=document.getElementById('p-'+k);if(el)el.value=p[k]||"";});
  document.getElementById('p-cat').value=p.categoria||'skincare';document.getElementById('p-forma').value=p.forma||'serum';document.getElementById('p-grau').value=p.grau||'1_notif';document.getElementById('p-sanv').value=p.sanv||'pendente';document.getElementById('p-pstatus').value=p.pstatus||'desenvolvimento';
  document.getElementById('t-prod').textContent='Editar Formulação';document.querySelector('#tabs-prod .tab').click();openM('m-prod');
}
function viewPr(id){
  const db=getDB(),p=db.produtos.find(x=>x.id===id);if(!p)return;
  document.getElementById('det-prod-t').textContent=p.nome;
  document.getElementById('btn-edit-pr').onclick=()=>{closeM('m-prod-det');editPr(id);};
  const m=p.custo&&p.varejo?((1-parseFloat(p.custo)/parseFloat(p.varejo))*100).toFixed(1)+'%':'—';
  document.getElementById('det-prod-b').innerHTML=`
    <div class="g2"><div>
      <div class="sh">Identificação</div>
      <div class="tf"><div class="tf-l">Categoria</div><div class="tf-v">${p.categoria||'—'}</div></div>
      <div class="tf"><div class="tf-l">Forma</div><div class="tf-v">${p.forma||'—'}</div></div>
      <div class="tf"><div class="tf-l">Volume</div><div class="tf-v">${p.vol||'—'}</div></div>
      <div class="tf"><div class="tf-l">pH</div><div class="tf-v">${p.ph||'—'}</div></div>
      <div class="tf"><div class="tf-l">Validade</div><div class="tf-v">${p.val?p.val+' meses':'—'}</div></div>
      <div class="tf"><div class="tf-l">PAO</div><div class="tf-v">${p.pao||'—'}</div></div>
    </div><div>
      <div class="sh">Comercial</div>
      <div class="tf"><div class="tf-l">Ativo Principal</div><div class="tf-v">${p.ativo?p.ativo+' '+p.conc:'—'}</div></div>
      <div class="tf"><div class="tf-l">Custo</div><div class="tf-v">${p.custo?brl(p.custo):'—'}</div></div>
      <div class="tf"><div class="tf-l">Preço Varejo</div><div class="tf-v">${p.varejo?brl(p.varejo):'—'}</div></div>
      <div class="tf"><div class="tf-l">Margem Bruta</div><div class="tf-v" style="color:var(--success);font-weight:600">${m}</div></div>
      <div class="tf"><div class="tf-l">Status Prod.</div><div class="tf-v">${badge(p.pstatus)}</div></div>
      <div class="tf"><div class="tf-l">Status Anvisa</div><div class="tf-v">${badge(p.sanv)}</div></div>
    </div></div>
    ${p.desc?`<div class="div"></div><div class="sh">Benefícios</div><p style="font-size:13px;color:var(--t2);line-height:1.7">${p.desc}</p>`:""}
    ${p.uso?`<div class="div"></div><div class="sh">Modo de Uso</div><p style="font-size:13px;color:var(--t2);line-height:1.7">${p.uso}</p>`:""}
    ${p.inci?`<div class="div"></div><div class="sh">Lista INCI</div><div style="font-family:monospace;font-size:12px;background:var(--s2);padding:11px;border-radius:7px;line-height:1.8">${p.inci}</div>`:""}
    ${p.claims?`<div class="div"></div><div class="ib ok"><strong>Claims:</strong> ${p.claims}</div>`:""}
    ${p.rest?`<div class="ib warn"><strong>Restrições:</strong> ${p.rest}</div>`:""}
  `;openM('m-prod-det');
}
function delPr(id){if(!confirm('Excluir produto?'))return;const db=getDB();db.produtos=db.produtos.filter(p=>p.id!==id);saveDB(db);rPr();toast('Removido','s');}
rPr();
</script>

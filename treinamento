function togTr(hdr){
  const body=hdr.nextElementSibling,arrow=hdr.querySelector('span:last-child'),isOpen=body.classList.contains('open');
  document.querySelectorAll('.tr-body').forEach(b=>b.classList.remove('open'));
  document.querySelectorAll('.tr-hdr span:last-child').forEach(a=>a.textContent='▸');
  if(!isOpen){body.classList.add('open');arrow.textContent='▾';}
}

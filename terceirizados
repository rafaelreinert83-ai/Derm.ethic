<script src="js/db.js"></script>
<script>
renderSidebar('terceirizados');
const TIPO_LBL={industria:"🏭 Indústria",embalagens:"📦 Embalagens",grafica:"🖨 Gráfica",marketing:"📣 Marketing",tecnico:"🔬 Técnico",juridico:"⚖ Jurídico",logistica:"🚚 Logística",outros:"Outros"};
function rTe(){
  const db=getDB();const q=(document.getElementById('q-te')?.value||"").toLowerCase();const ft=document.getElementById('fil-te').value;
  let list=db.terceirizados.filter(t=>(t.nome?.toLowerCase().includes(q)||t.serv?.toLowerCase().includes(q))&&(!ft||t.tipo===ft));
  const tb=document.getElementById('tb-te'),emp=document.getElementById('emp-te'),tc=document.getElementById('tc-te');
  if(!list.length){tb.innerHTML="";emp.style.display="block";tc.style.display="none";}
  else{emp.style.display="none";tc.style.display="block";
    tb.innerHTML=list.map(t=>`<tr><td><strong>${t.nome}</strong></td><td><span class="badge bg-blue">${TIPO_LBL[t.tipo]||t.tipo}</span></td><td style="font-size:12px">${t.serv||"—"}</td><td>${t.cont||"—"}<br><small>${t.tel||""}</small></td><td style="font-size:12px">${t.valor||"—"}</td><td>${badge(t.status)}</td><td><div style="display:flex;gap:4px"><button class="btn-ic" onclick="editTe('${t.id}')">✏️</button><button class="btn-ic" onclick="delTe('${t.id}')" style="border-color:var(--danger);color:var(--danger)">🗑</button></div></td></tr>`).join("");
  }
}
function saveTe(){
  const id=document.getElementById('te-id').value,db=getDB();
  const o={id:id||genID(),nome:document.getElementById('te-nome').value.trim(),tipo:document.getElementById('te-tipo').value,serv:document.getElementById('te-serv').value.trim(),cnpj:document.getElementById('te-cnpj').value.trim(),cont:document.getElementById('te-cont').value.trim(),tel:document.getElementById('te-tel').value.trim(),email:document.getElementById('te-email').value.trim(),valor:document.getElementById('te-valor').value.trim(),status:document.getElementById('te-status').value,obs:document.getElementById('te-obs').value.trim()};
  if(!o.nome){toast('Nome obrigatório','e');return;}
  if(id){const i=db.terceirizados.findIndex(x=>x.id===id);if(i>=0)db.terceirizados[i]=o;}else db.terceirizados.push(o);
  saveDB(db);closeM('m-te');rTe();toast('Parceiro salvo!','s');document.getElementById('te-id').value='';
}
function editTe(id){const db=getDB(),t=db.terceirizados.find(x=>x.id===id);if(!t)return;document.getElementById('te-id').value=t.id;['nome','serv','cnpj','cont','tel','email','valor','obs'].forEach(k=>{const el=document.getElementById('te-'+k);if(el)el.value=t[k]||'';});document.getElementById('te-tipo').value=t.tipo;document.getElementById('te-status').value=t.status;openM('m-te');}
function delTe(id){if(!confirm('Excluir?'))return;const db=getDB();db.terceirizados=db.terceirizados.filter(t=>t.id!==id);saveDB(db);rTe();toast('Removido','s');}
rTe();
</script>

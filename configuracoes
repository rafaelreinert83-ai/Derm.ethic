<script>
renderSidebar('configuracoes');

function lCfg(){
const db=getDB();
document.getElementById(‘cfg-key’).value=db.cfg?.key||’’;
document.getElementById(‘cfg-model’).value=db.cfg?.model||‘claude-sonnet-4-20250514’;
document.getElementById(‘cfg-ig’).value=db.cfg?.ig||’’;
document.getElementById(‘cfg-email’).value=db.cfg?.email||’’;
document.getElementById(‘cfg-zap’).value=db.cfg?.zap||’’;
document.getElementById(‘cfg-site’).value=db.cfg?.site||’’;
const hasKey=!!db.cfg?.key;
document.getElementById(‘api-status-display’).innerHTML=hasKey?’<div class="ib ok">✅ API Key configurada e pronta para uso no chat de IA.</div>’:’<div class="ib warn">⚠ API Key não configurada. A IA de Comunicação não está disponível.</div>’;
buildSummary(db);buildDiagnostico(db);
}

function buildSummary(db){
document.getElementById(‘data-summary’).innerHTML=` <div class="tf"><div class="tf-l">Clientes</div><div class="tf-v">${db.clientes.length} cadastrados</div></div> <div class="tf"><div class="tf-l">Fornecedores</div><div class="tf-v">${db.fornecedores.length} cadastrados</div></div> <div class="tf"><div class="tf-l">Terceirizados</div><div class="tf-v">${db.terceirizados.length} cadastrados</div></div> <div class="tf"><div class="tf-l">Produtos</div><div class="tf-v">${db.produtos.length} formulações</div></div> <div class="tf"><div class="tf-l">Notas Fiscais</div><div class="tf-v">${db.nfs.length} registradas</div></div> <div class="tf"><div class="tf-l">Campanhas</div><div class="tf-v">${db.campanhas.length} cadastradas</div></div> <div class="tf"><div class="tf-l">Personas</div><div class="tf-v">${db.personas.length} definidas</div></div> <div class="tf"><div class="tf-l">Tamanho estimado</div><div class="tf-v">${(JSON.stringify(db).length/1024).toFixed(1)} KB no localStorage</div></div>`;
}

function buildDiagnostico(db){
const items=[
{ok:db.clientes.length>0,lbl:‘Clientes cadastrados’},
{ok:db.produtos.length>0,lbl:‘Produtos formulados’},
{ok:db.fornecedores.length>0,lbl:‘Fornecedores cadastrados’},
{ok:!!db.cfg?.key,lbl:‘API Key Anthropic configurada’},
{ok:db.personas.length>0,lbl:‘Personas de marketing definidas’},
{ok:db.nfs.length>0,lbl:‘Notas fiscais registradas’},
{ok:db.custos_op.length>0,lbl:‘Custos operacionais lançados’},
{ok:db.produtos.some(p=>p.sanv===‘registrado’),lbl:‘Produto com Anvisa regularizado’},
];
document.getElementById(‘diagnostico’).innerHTML=items.map(i=>`<div class="alert-item ${i.ok?'ok':'warn'}"><span>${i.ok?'✅':'⚠️'}</span><span>${i.lbl}</span></div>`).join(’’);
}

function toggleKey(){const inp=document.getElementById(‘cfg-key’);inp.type=inp.type===‘password’?‘text’:‘password’;}

function saveApiCfg(){
const db=getDB();if(!db.cfg)db.cfg={};
db.cfg.key=document.getElementById(‘cfg-key’).value.trim();
db.cfg.model=document.getElementById(‘cfg-model’).value;
saveDB(db);lCfg();toast(‘Configurações de IA salvas!’,‘s’);
}

function saveCfgEmp(){
const db=getDB();if(!db.cfg)db.cfg={};
db.cfg.ig=document.getElementById(‘cfg-ig’).value.trim();
db.cfg.email=document.getElementById(‘cfg-email’).value.trim();
db.cfg.zap=document.getElementById(‘cfg-zap’).value.trim();
db.cfg.site=document.getElementById(‘cfg-site’).value.trim();
saveDB(db);toast(‘Dados comerciais salvos!’,‘s’);
}

function exportDB(){
const db=getDB();
const a=document.createElement(‘a’);
a.href=URL.createObjectURL(new Blob([JSON.stringify(db,null,2)],{type:‘application/json’}));
a.download=`dermethic-backup-${new Date().toISOString().split('T')[0]}.json`;
a.click();toast(‘Backup exportado com sucesso!’,‘s’);
}

function importDB(e){
const file=e.target.files[0];if(!file)return;
const r=new FileReader();
r.onload=ev=>{try{const db=JSON.parse(ev.target.result);saveDB(db);lCfg();toast(‘Dados importados com sucesso!’,‘s’);}catch{toast(‘Arquivo JSON inválido!’,‘e’);}};
r.readAsText(file);
}

function resetDB(){
if(!confirm(‘ATENÇÃO: Isso apagará TODOS os dados e voltará para os exemplos iniciais. Confirmar?’))return;
localStorage.removeItem(‘dermethic_v1’);toast(‘Dados resetados. Recarregue a página.’,‘w’);setTimeout(()=>location.reload(),1500);
}

lCfg();
</script>


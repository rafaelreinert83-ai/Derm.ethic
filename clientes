      <div class="fr"><div class="fg"><label class="flbl">Telefone / WhatsApp</label><input type="text" class="fi" id="c-tel" placeholder="(47) 9xxxx-xxxx"></div><div class="fg"><label class="flbl">E-mail</label><input type="email" class="fi" id="c-email"></div></div>

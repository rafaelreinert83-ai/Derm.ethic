      <div class="fr"><div class="fg"><label class="flbl">Tipo</label><select class="fs" id="c-tipo" onchange="togCli()"><option value="PF">Pessoa Física</option><option value="PJ">Pessoa Jurídica</option></select></div><div class="fg"><label class="flbl">Status</label><select class="fs" id="c-status"><option value="ativo">Ativo</option><option value="prospecto">Prospecto</option><option value="inativo">Inativo</option></select></div></div>

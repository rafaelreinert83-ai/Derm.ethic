    <div class="mhdr"><div class="mtitle" id="t-cl-det">Cliente</div><button class="mclose" onclick="closeM('m-cl-det')">✕</button></div>
    <div class="mbody" id="b-cl-det"></div>
    <div class="mfoot"><button class="btn btn-o" onclick="closeM('m-cl-det')">Fechar</button><button class="btn btn-p" id="btn-edit-cl">✏️ Editar</button></div>

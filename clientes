<div class="tcon" id="tcon"></div>
<script src="js/db.js"></script>
<script>
renderSidebar('clientes');

const CANAL_LBL={farmacia:‘💊 Farmácia’,salao:‘✂️ Salão’,loja_especializada:‘🛍 Loja Esp.’,supermercado:‘🛒 Supermercado’,ecommerce:‘🌐 E-commerce’,direto:‘👤 Direto’,distribuidor:‘🚚 Distribuidor’};

function rCl(){
const db=getDB();
const q=(document.getElementById(‘q-cl’)?.value||’’).toLowerCase();
const fc=document.getElementById(‘fil-canal’).value;
const fs=document.getElementById(‘fil-status’).value;
let list=db.clientes.filter(c=>{
const mq=c.nome?.toLowerCase().includes(q)||c.doc?.toLowerCase().includes(q)||c.email?.toLowerCase().includes(q)||c.cidade?.toLowerCase().includes(q);
const mc=!fc||c.canal===fc;
const ms=!fs||c.status===fs;
return mq&&mc&&ms;
});
const tb=document.getElementById(‘tb-cl’),emp=document.getElementById(‘emp-cl’),tc=document.getElementById(‘tc-cl’);
if(!list.length){tb.innerHTML=’’;emp.style.display=‘block’;tc.style.display=‘none’;}
else{emp.style.display=‘none’;tc.style.display=‘block’;
tb.innerHTML=list.map(c=>`<tr style="cursor:pointer" onclick="viewCl('${c.id}')"> <td><strong>${c.nome}</strong></td> <td><span class="badge ${c.tipo==='PJ'?'bg-blue':'bg-sage'}">${c.tipo}</span></td> <td style="font-size:11px;color:var(--muted)">${c.doc||'—'}</td> <td>${c.tel||'—'}</td><td style="font-size:12px">${c.email||'—'}</td> <td>${c.cidade||'—'}${c.uf?' – '+c.uf:''}</td> <td>${c.canal?`<span class="badge bg-blue" style="font-size:10px">${CANAL_LBL[c.canal]||c.canal}</span>`:'—'}</td> <td>${badge(c.status)}</td> <td onclick="event.stopPropagation()"><div style="display:flex;gap:4px"> <button class="btn-ic" onclick="editCl('${c.id}')">✏️</button> <button class="btn-ic" onclick="delCl('${c.id}')" style="border-color:var(--danger);color:var(--danger)">🗑</button> </div></td></tr>`).join(’’);
}
buildSeg();
}

function buildSeg(){
const db=getDB();
const byCanal={};
db.clientes.forEach(c=>{const k=c.canal||‘outros’;byCanal[k]=(byCanal[k]||0)+1;});
const byStatus={ativo:0,prospecto:0,inativo:0};
db.clientes.forEach(c=>{byStatus[c.status]=(byStatus[c.status]||0)+1;});
document.getElementById(‘seg-content’).innerHTML=` <div class="g2"> <div class="card"><div class="card-title">📊 Por Canal de Venda</div> ${Object.entries(byCanal).map(([k,v])=>`<div class="tf"><div class="tf-l">${CANAL_LBL[k]||k}</div><div class="tf-v"><strong>${v}</strong> cliente(s)<div class="progress-bar"><div class="progress-fill" style="width:${Math.round(v/db.clientes.length*100)}%"></div></div></div></div>`).join('')} </div> <div class="card"><div class="card-title">📊 Por Status</div> <div class="tf"><div class="tf-l">Ativos</div><div class="tf-v"><strong>${byStatus.ativo}</strong> — <span style="color:var(--success)">${db.clientes.length?Math.round(byStatus.ativo/db.clientes.length*100):0}%</span><div class="progress-bar"><div class="progress-fill" style="width:${db.clientes.length?Math.round(byStatus.ativo/db.clientes.length*100):0}%;background:var(--success)"></div></div></div></div> <div class="tf"><div class="tf-l">Prospectos</div><div class="tf-v"><strong>${byStatus.prospecto}</strong> — <span style="color:var(--warning)">${db.clientes.length?Math.round(byStatus.prospecto/db.clientes.length*100):0}%</span><div class="progress-bar"><div class="progress-fill" style="width:${db.clientes.length?Math.round(byStatus.prospecto/db.clientes.length*100):0}%;background:var(--warning)"></div></div></div></div> <div class="tf"><div class="tf-l">Inativos</div><div class="tf-v"><strong>${byStatus.inativo}</strong> — <span style="color:var(--danger)">${db.clientes.length?Math.round(byStatus.inativo/db.clientes.length*100):0}%</span></div></div> <div class="div"></div> <div class="ib tip"><strong>Meta:</strong> Manter taxa de ativos acima de 75% e taxa de conversão de prospectos acima de 40%.</div> </div> </div>`;
}

function togCli(){const t=document.getElementById(‘c-tipo’).value;document.getElementById(‘lbl-nome’).textContent=t===‘PJ’?‘Razão Social’:‘Nome Completo’;document.getElementById(‘lbl-doc’).textContent=t===‘PJ’?‘CNPJ’:‘CPF’;document.getElementById(‘fi-ie’).style.display=t===‘PJ’?‘block’:‘none’;}

function saveCl(){
const id=document.getElementById(‘c-id’).value,db=getDB();
const o={id:id||genID(),tipo:document.getElementById(‘c-tipo’).value,nome:document.getElementById(‘c-nome’).value.trim(),doc:document.getElementById(‘c-doc’).value.trim(),ie:document.getElementById(‘c-ie’).value.trim(),tel:document.getElementById(‘c-tel’).value.trim(),email:document.getElementById(‘c-email’).value.trim(),cidade:document.getElementById(‘c-cidade’).value.trim(),uf:document.getElementById(‘c-uf’).value.trim(),end:document.getElementById(‘c-end’).value.trim(),canal:document.getElementById(‘c-canal’).value,status:document.getElementById(‘c-status’).value,obs:document.getElementById(‘c-obs’).value.trim()};
if(!o.nome){toast(‘Nome é obrigatório’,‘e’);return;}
if(id){const i=db.clientes.findIndex(x=>x.id===id);if(i>=0)db.clientes[i]={…db.clientes[i],…o};}else db.clientes.push(o);
saveDB(db);closeM(‘m-cl’);rCl();toast(id?‘Cliente atualizado!’:‘Cliente cadastrado!’,‘s’);
document.getElementById(‘c-id’).value=’’;document.getElementById(‘t-cl’).textContent=‘Novo Cliente’;
}

function editCl(id){
const db=getDB(),c=db.clientes.find(x=>x.id===id);if(!c)return;
document.getElementById(‘c-id’).value=c.id;document.getElementById(‘c-tipo’).value=c.tipo;togCli();
[‘nome’,‘doc’,‘ie’,‘tel’,‘email’,‘cidade’,‘uf’,‘end’,‘obs’].forEach(k=>{const el=document.getElementById(‘c-’+k);if(el)el.value=c[k]||’’;});
document.getElementById(‘c-canal’).value=c.canal||’’;document.getElementById(‘c-status’).value=c.status||‘ativo’;
document.getElementById(‘t-cl’).textContent=‘Editar Cliente’;openM(‘m-cl’);
}

function viewCl(id){
const db=getDB(),c=db.clientes.find(x=>x.id===id);if(!c)return;
document.getElementById(‘t-cl-det’).textContent=c.nome;
document.getElementById(‘btn-edit-cl’).onclick=()=>{closeM(‘m-cl-det’);editCl(id);};
document.getElementById(‘b-cl-det’).innerHTML=` <div class="tf"><div class="tf-l">Tipo</div><div class="tf-v">${c.tipo==='PJ'?'Pessoa Jurídica':'Pessoa Física'}</div></div> <div class="tf"><div class="tf-l">${c.tipo==='PJ'?'CNPJ':'CPF'}</div><div class="tf-v">${c.doc||'—'}</div></div> <div class="tf"><div class="tf-l">Telefone</div><div class="tf-v">${c.tel||'—'}</div></div> <div class="tf"><div class="tf-l">E-mail</div><div class="tf-v">${c.email||'—'}</div></div> <div class="tf"><div class="tf-l">Localização</div><div class="tf-v">${c.cidade||'—'}${c.uf?' – '+c.uf:''}</div></div> <div class="tf"><div class="tf-l">Endereço</div><div class="tf-v">${c.end||'—'}</div></div> <div class="tf"><div class="tf-l">Canal</div><div class="tf-v">${CANAL_LBL[c.canal]||'—'}</div></div> <div class="tf"><div class="tf-l">Status</div><div class="tf-v">${badge(c.status)}</div></div> ${c.obs?`<div class="div"></div><div class="sh">Observações</div><p style="font-size:13px;color:var(--t2);line-height:1.7">${c.obs}</p>`:''} <div class="div"></div> <div class="g2"> <a href="tel:${c.tel}" class="btn btn-o btn-sm">📞 Ligar</a> <a href="https://wa.me/55${c.tel?.replace(/\D/g,'')}" target="_blank" class="btn btn-s btn-sm">💚 WhatsApp</a> </div>`;
openM(‘m-cl-det’);
}

function delCl(id){if(!confirm(‘Excluir cliente?’))return;const db=getDB();db.clientes=db.clientes.filter(c=>c.id!==id);saveDB(db);rCl();toast(‘Cliente removido’,‘s’);}

rCl();
</script>

